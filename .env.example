# ──────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────
# Pooled connection for the app (Neon / any PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ──────────────────────────────────────────────
# AUTHENTICATION (NextAuth)
# ──────────────────────────────────────────────
