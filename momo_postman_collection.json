  ],
  "item": [
    {
      "name": "1. Collections (Deposits & Repayments)",
      "item": [
        {
          "name": "1.1 Get Collections Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('collectionsToken', jsonData.access_token);",
                  "pm.test('Token acquired', function () {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(jsonData.access_token).to.not.be.empty;",
                  "});",
                  "console.log('Collections Token saved automatically.');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Ocp-Apim-Subscription-Key",
                "value": "{{collectionsSubKey}}"
              }
            ],
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{collectionsApiUser}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{collectionsApiKey}}",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "https://sandbox.momodeveloper.mtn.com/collection/token/",
              "protocol": "https",
              "host": [
                "sandbox",
                "momodeveloper",
                "mtn",
                "com"
              ],
              "path": [
                "collection",
                "token",
                ""
              ]
            }
          }
        },
        {
          "name": "1.2 Request to Pay (Collect Money)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var referenceId = pm.variables.replaceIn('{{$guid}}');",
                  "pm.collectionVariables.set('paymentReferenceId', referenceId);",
                  "console.log('Generated Reference ID:', referenceId);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Request to Pay accepted', function () {",
                  "    pm.response.to.have.status(202);",
                  "});",
                  "console.log('Payment Reference:', pm.collectionVariables.get('paymentReferenceId'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Reference-Id",
                "value": "{{paymentReferenceId}}"
              },
              {
                "key": "X-Target-Environment",
                "value": "sandbox"
              },
              {
                "key": "Ocp-Apim-Subscription-Key",
                "value": "{{collectionsSubKey}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{collectionsToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": \"1000\",\n  \"currency\": \"EUR\",\n  \"externalId\": \"SACCO-DEP-001\",\n  \"payer\": {\n    \"partyIdType\": \"MSISDN\",\n    \"partyId\": \"46733123453\"\n  },\n  \"payerMessage\": \"SACCO Deposit Payment\",\n  \"payeeNote\": \"Deposit to member account\"\n}"
            },
            "url": {
              "raw": "https://sandbox.momodeveloper.mtn.com/collection/v1_0/requesttopay",
              "protocol": "https",
              "host": [
                "sandbox",
                "momodeveloper",
                "mtn",
                "com"
              ],
              "path": [
                "collection",
                "v1_0",
                "requesttopay"
              ]
            }
          }
        },
        {
          "name": "1.3 Check Payment Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.test('Status retrieved', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "console.log('Payment Status:', jsonData.status);",
                  "console.log('Amount:', jsonData.amount, jsonData.currency);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Target-Environment",
                "value": "sandbox"
              },
              {
                "key": "Ocp-Apim-Subscription-Key",
                "value": "{{collectionsSubKey}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{collectionsToken}}"
              }
            ],
            "url": {
              "raw": "https://sandbox.momodeveloper.mtn.com/collection/v1_0/requesttopay/{{paymentReferenceId}}",
              "protocol": "https",
              "host": [
                "sandbox",
                "momodeveloper",
                "mtn",
                "com"
              ],
              "path": [
                "collection",
                "v1_0",
                "requesttopay",
                "{{paymentReferenceId}}"
              ]
            }
          }
        },
        {
          "name": "1.4 Request to Pay (FAIL - Insufficient Funds)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('paymentReferenceId', pm.variables.replaceIn('{{$guid}}'));"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Request accepted (will fail async)', function () {",
                  "    pm.response.to.have.status(202);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Reference-Id",
                "value": "{{paymentReferenceId}}"
              },
              {
                "key": "X-Target-Environment",
                "value": "sandbox"
              },
              {
                "key": "Ocp-Apim-Subscription-Key",
                "value": "{{collectionsSubKey}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{collectionsToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": \"1000\",\n  \"currency\": \"EUR\",\n  \"externalId\": \"SACCO-FAIL-001\",\n  \"payer\": {\n    \"partyIdType\": \"MSISDN\",\n    \"partyId\": \"46733123454\"\n  },\n  \"payerMessage\": \"This will fail - insufficient funds\",\n  \"payeeNote\": \"Test failure scenario\"\n}"
            },
            "url": {
              "raw": "https://sandbox.momodeveloper.mtn.com/collection/v1_0/requesttopay",
              "protocol": "https",
              "host": [
                "sandbox",
                "momodeveloper",
                "mtn",
                "com"
              ],
              "path": [
                "collection",
                "v1_0",
                "requesttopay"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2. Disbursements (Withdrawals)",
