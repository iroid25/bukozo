              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": \"5000\",\n  \"currency\": \"EUR\",\n  \"externalId\": \"SACCO-WITHDRAW-001\",\n  \"payee\": {\n    \"partyIdType\": \"MSISDN\",\n    \"partyId\": \"46733123453\"\n  },\n  \"payerMessage\": \"SACCO Withdrawal\",\n  \"payeeNote\": \"Withdrawal from member account\"\n}"
            },
            "url": {
              "raw": "https://sandbox.momodeveloper.mtn.com/disbursement/v1_0/transfer",
              "protocol": "https",
              "host": [
                "sandbox",
                "momodeveloper",
                "mtn",
                "com"
              ],
              "path": [
                "disbursement",
                "v1_0",
                "transfer"
              ]
            }
          }
        },
        {
          "name": "2.3 Check Transfer Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.test('Status retrieved', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "console.log('Transfer Status:', jsonData.status);",
                  "console.log('Amount:', jsonData.amount, jsonData.currency);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
