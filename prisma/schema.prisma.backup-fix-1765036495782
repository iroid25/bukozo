enum AccountLedgerType {
  ASSETS
  LIABILITIES
  EQUITY
  INCOME
  EXPENSES
}

model ChartOfAccount {
  id          String @id @default(cuid())
  accountCode String @unique
  accountName String
  fullCode    String @unique

  // Hierarchy
  parentId String?
  parent   ChartOfAccount?  @relation("AccountHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children ChartOfAccount[] @relation("AccountHierarchy")
  level    Int

  // Classification
  ledgerType AccountLedgerType
  category   String?
  product    String?

  // Properties
  currency    String  @default("UGX")
  debitCredit String?
  isActive    Boolean @default(true)
  isSystem    Boolean @default(false)

  // Balance tracking
  balance       Float @default(0)
  debitBalance  Float @default(0)
  creditBalance Float @default(0)

  // Metadata
  description String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  journalEntries     JournalEntry[]
  debitTransactions  AccountTransaction[] @relation("DebitAccount")
  creditTransactions AccountTransaction[] @relation("CreditAccount")
  transactionDebits  Transaction[]        @relation("TransactionDebit")
  transactionCredits Transaction[]        @relation("TransactionCredit")

  @@index([accountCode])
  @@index([ledgerType])
  @@index([parentId])
  @@index([isActive])
}

model JournalEntry {
  id          String   @id @default(cuid())
  entryNumber String   @unique
  entryDate   DateTime @default(now())
  description String
  reference   String?

  // Relations
  accountId String
  account   ChartOfAccount @relation(fields: [accountId], references: [id])

  debitAmount  Float @default(0)
  creditAmount Float @default(0)

  // Transaction link
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  // Audit
  createdByUserId String
  createdBy       User     @relation(fields: [createdByUserId], references: [id])
  createdAt       DateTime @default(now())

  @@index([accountId])
  @@index([entryDate])
  @@index([transactionId])
}

model AccountTransaction {
  id             String @id @default(cuid())
  transactionRef String @unique

  // Double-entry accounts
  debitAccountId String
  debitAccount   ChartOfAccount @relation("DebitAccount", fields: [debitAccountId], references: [id])

  creditAccountId String
  creditAccount   ChartOfAccount @relation("CreditAccount", fields: [creditAccountId], references: [id])

  amount          Float
  description     String
  transactionDate DateTime @default(now())

  // Link to existing transaction
  linkedTransactionId String?
  linkedTransaction   Transaction? @relation(fields: [linkedTransactionId], references: [id])

  // Audit
  createdByUserId String
  createdBy       User     @relation(fields: [createdByUserId], references: [id])
  createdAt       DateTime @default(now())

  @@index([debitAccountId])
  @@index([creditAccountId])
  @@index([transactionDate])
}
