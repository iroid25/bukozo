// =====================
// Vault Models
// =====================

model Vault {
  id           String    @id @default(cuid())
  name         String    @unique
  branchId     String?
  branch       Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  balance      Float     @default(0)
  physicalCash Float     @default(0)
  lastVerified DateTime?
  isActive     Boolean   @default(true)
  location     String?

  custodianUserId String?
  custodian       User?   @relation("VaultCustodian", fields: [custodianUserId], references: [id], onDelete: SetNull)

  vaultTransactions    VaultTransaction[]
  vaultReconciliations VaultReconciliation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId])
  @@index([isActive])
}

model VaultTransaction {
  id              String               @id @default(cuid())
  vaultId         String
  vault           Vault                @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  type            VaultTransactionType
  amount          Float
  balanceBefore   Float
  balanceAfter    Float
  transactionDate DateTime             @default(now())
  description     String?

  relatedFloatAllocationId     String?
  relatedFloatReconciliationId String?
  relatedUserId                String?
  relatedUser                  User?   @relation("VaultTransactionUser", fields: [relatedUserId], references: [id], onDelete: SetNull)

  performedByUserId String
  performedBy       User   @relation("VaultTransactionPerformedBy", fields: [performedByUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([vaultId])
  @@index([type])
  @@index([transactionDate])
}

model VaultReconciliation {
  id                 String   @id @default(cuid())
  vaultId            String
  vault              Vault    @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  reconciliationDate DateTime @default(now())

  systemBalance Float
  physicalCash  Float
  difference    Float
  isBalanced    Boolean

  reconciledByUserId String
  reconciledBy       User   @relation("VaultReconciler", fields: [reconciledByUserId], references: [id], onDelete: Cascade)

  status           ReconciliationStatus @default(PENDING)
  approvedByUserId String?
  approvedBy       User?                @relation("VaultReconciliationApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  approvalDate     DateTime?

  notes String?

  @@index([vaultId])
  @@index([reconciliationDate])
  @@index([status])
}

// =====================
// Notification & Audit
// =====================

model Notification {
  id            String           @id @default(cuid())
  userId        String?
  user          User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  type          NotificationType
  subject       String?
  message       String
  sentAt        DateTime         @default(now())
  isRead        Boolean          @default(false)
  targetAddress String?
  status        String?

  @@index([userId])
  @@index([type])
  @@index([sentAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String
  entityType String
  entityId   String?
  oldValue   Json?
  newValue   Json?
  timestamp  DateTime @default(now())
  ipAddress  String?
  browser    String?
  os         String?
  details    String?

  @@index([userId])
  @@index([entityType])
  @@index([timestamp])
}

model ApiKey {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  createdAt DateTime @default(now())
}

// =====================
// Member Models
// =====================

model Member {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  memberNumber     String   @unique
  registrationDate DateTime @default(now())
  isApproved       Boolean  @default(false)

  surname       String?
  otherNames    String?
  age           Int?
  gender        Gender?
  maritalStatus MaritalStatus?
  maritalOther  String?

  nokName            String?
  nokRelationship    String?
  nokPhone           String?
  numberOfChildren   Int?
  numberOfDependants Int?

  levelOfEducation           String?
  citizenship                String?
  occupation                 String?
  otherFinancialInstitutions String?
  fatherName                 String?
  motherName                 String?

  village       String?
  parish        String?
  subCounty     String?
  constituency  String?
  town          String?
  district      String?
  postalAddress String?

  nin      String?
  typeOfId String?

  certifiedBy        String?
  certifierAccountNo String?
  certifierPhone     String?
  certifierSignature String?
  certificationDate  DateTime?

  withdrawalInstructions String?

  applicantOccupationLC String?
  designationLC         String?
  locationLC            String?
  otherSaccosCount      OtherSaccosCount?
  financialDiscipline   FinancialDiscipline?
  recommenderName       String?
  recommenderTitle      String?
  recommenderPhone      String?
  recommenderSignature  String?
  recommendationDate    DateTime?

  entryFee           Float?
  initialSavings     Float?
  nominee            String?
  applicantSignature String?

  approvalDate         DateTime?
  rejectionReason      String?
  savingsAccountNumber String?
  managerSignature     String?
  cashierSignature     String?
  officialStamp        String?

  passportPhoto  String?
  idCopyPath     String?
  additionalDocs String[]

  accounts                Account[]
  loanApplications        LoanApplication[]        @relation("MemberLoanApplications")
  loanRepayments          LoanRepayment[]          @relation("MemberLoanRepayments")
  transactions            Transaction[]            @relation("MemberTransactions")
  statements              Statement[]
  deposits                Deposit[]                @relation("MemberDeposits")
  withdrawals             Withdrawal[]             @relation("MemberWithdrawals")
  loans                   Loan[]
  withdrawalVerifications WithdrawalVerification[]
  loanAppeals             LoanAppeal[]             @relation("MemberLoanAppeals")
  incomeRecords           IncomeRecord[]           @relation("MemberIncomeRecords")

  // Insurance Relations
  insuranceContributions InsuranceContribution[]

  // ✅ ADD THIS LINE (without @relation name)
  loanRepaymentRequests LoanRepaymentRequest[]

  // Extended Account Relations (Manager Reports)
  savingsAccounts         SavingsAccount[]
  shareAccounts           ShareAccount[]
  fixedDeposits           FixedDeposit[]

  // SMS & Feedback Relations (Manager Reports)
  smsLogs                 SmsLog[]
  customerFeedback        CustomerFeedback[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberNumber])
  @@index([registrationDate])
  @@index([userId])
}

// =====================
// Account Modelsx`x`x`
// =====================

model AccountType {
  id             String  @id @default(cuid())
  name           String  @unique
  interestRate   Float   @default(0)
  interestPeriod String  @default("MONTHLY")
  minBalance     Float   @default(0)
  isDefault      Boolean @default(false)
  maxWithdrawal  Float?
  isLoanEligible Boolean @default(true)

  monthlyCharge               Float?
  withdrawalFeeTiers          String?
  flatWithdrawalFee           Float?
  withdrawalFrequencyDays     Int?
  maxWithdrawalsPerDay        Int?
  hasFixedPeriod              Boolean @default(false)
  fixedPeriodMonths           Int?
  maturityTransferAccountType String?
  isShareAccount              Boolean @default(false)
  canWithdraw                 Boolean @default(true)
  earnsDividends              Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]

  @@index([name])
}

model Account {
  id            String @id @default(cuid())
  accountNumber String @unique

  memberId String?
  member   Member? @relation(fields: [memberId], references: [id], onDelete: Cascade)

  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)

  accountTypeId String
  accountType   AccountType   @relation(fields: [accountTypeId], references: [id], onDelete: Cascade)
  balance       Float         @default(0)
  status        AccountStatus @default(ACTIVE)
  openedAt      DateTime      @default(now())
  closedAt      DateTime?
  branchId      String
  branch        Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)

  transactions            Transaction[]
  deposits                Deposit[]
  withdrawals             Withdrawal[]
  withdrawalVerifications WithdrawalVerification[]
  incomeRecords           IncomeRecord[]           @relation("AccountIncomeRecords")

  // Insurance Relations
  insuranceContributions InsuranceContribution[]

  loanRepaymentRequests LoanRepaymentRequest[]

  @@index([accountNumber])
  @@index([memberId])
  @@index([institutionId])
  @@index([accountTypeId])
  @@index([branchId])
}

// =====================
// Transaction Models
// =====================

model Transaction {
  id                   String            @id @default(cuid())
  transactionRef       String            @unique
  memberId             String?           @map("sourceMemberId")
  member               Member?           @relation("MemberTransactions", fields: [memberId], references: [id], onDelete: Cascade)
  accountId            String            @map("targetAccountId")
  account              Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type                 TransactionType
  amount               Float             @default(0)
  currency             String            @default("UGX")
  exchangeRate         Float             @default(1.0)
  status               TransactionStatus @default(PENDING)
  description          String?
  transactionDate      DateTime          @default(now())
  valueDate            DateTime?
  processedByUserId    String?
  processedByUser      User?             @relation(fields: [processedByUserId], references: [id], onDelete: SetNull)
  branchId             String?
  customerId           String?
  loanId               String?
  scheduleId           String?
  paymentMethod        String?
  paymentReference     String?
  notes                String?
  relatedTransactionId String?
  externalReference    String?
  channel              String?

  institutionId String?
  institution   Institution? @relation("InstitutionTransactions", fields: [institutionId], references: [id], onDelete: SetNull)

  deposit    Deposit?
  withdrawal Withdrawal?

  // Chart of Accounts relations
  debitAccountId      String?
  debitAccount        ChartOfAccount?      @relation("TransactionDebit", fields: [debitAccountId], references: [id], onDelete: SetNull)
  creditAccountId     String?
  creditAccount       ChartOfAccount?      @relation("TransactionCredit", fields: [creditAccountId], references: [id], onDelete: SetNull)
  journalEntries      JournalEntry[]
  accountTransactions AccountTransaction[]

  @@index([memberId])
  @@index([accountId])
  @@index([type])
  @@index([transactionDate])
  @@index([status])
  @@index([institutionId])
}

model Deposit {
  id            String      @id @default(cuid())
  transactionId String      @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  institutionId  String?
  institution    Institution? @relation("InstitutionDeposits", fields: [institutionId], references: [id], onDelete: Cascade)
  memberId       String?
  member         Member?      @relation("MemberDeposits", fields: [memberId], references: [id], onDelete: Cascade)
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  amount         Float
  depositDate    DateTime     @default(now())
  handlerUserId  String
  handler        User         @relation("DepositHandler", fields: [handlerUserId], references: [id], onDelete: Cascade)
  channel        String
  mobileMoneyRef String?

  depositorName String? // Name of person bringing the money

  @@index([memberId])
  @@index([handlerUserId])
}

model Withdrawal {
  id            String      @id @default(cuid())
  transactionId String      @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  memberId String?
  member   Member? @relation("MemberWithdrawals", fields: [memberId], references: [id], onDelete: Cascade)

  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  amount         Float
  withdrawalDate DateTime @default(now())

  handlerUserId String
  handler       User   @relation("WithdrawalHandler", fields: [handlerUserId], references: [id], onDelete: Cascade)

  channel        String
  mobileMoneyRef String?

  @@index([memberId])
  @@index([institutionId])
  @@index([handlerUserId])
}

model WithdrawalVerification {
  id               String   @id @default(cuid())
  memberId         String
  member           Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  accountId        String
  account          Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  amount           Float
  channel          String
  mobileMoneyRef   String?
  description      String?
  verificationCode String
  handlerUserId    String
  handler          User     @relation("WithdrawalVerificationHandler", fields: [handlerUserId], references: [id], onDelete: Cascade)
  expiresAt        DateTime
  emailSent        Boolean  @default(false)
  smsSent          Boolean  @default(false)
  isUsed           Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([memberId])
  @@index([accountId])
  @@index([handlerUserId])
  @@index([verificationCode])
  @@index([expiresAt])
  @@index([isUsed])
}

// =====================
// Loan Models
// =====================

model LoanProduct {
  id                  String   @id @default(cuid())
  name                String   @unique
  minAmount           Float
  maxAmount           Float
  interestRate        Float
  repaymentPeriodDays Int
  description         String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  loanApplications            LoanApplication[]
  institutionLoanApplications InstitutionLoanApplication[]

  @@index([name])
}

model LoanApplication {
  id            String      @id @default(cuid())
  loanProductId String
  loanProduct   LoanProduct @relation(fields: [loanProductId], references: [id], onDelete: Cascade)
  memberId      String
  loanOfficerId String?
  loanOfficer   User?       @relation("LoanOfficer", fields: [loanOfficerId], references: [id], onDelete: SetNull)
  member        Member      @relation("MemberLoanApplications", fields: [memberId], references: [id], onDelete: Cascade)

  amountApplied   Float
  applicationDate DateTime   @default(now())
  status          LoanStatus @default(PENDING)
  stage           LoanStage  @default(DRAFT)
  purpose         String?

  applicantId       String?
  applicant         User?   @relation("LoanApplicant", fields: [applicantId], references: [id], onDelete: SetNull)
  approverId        String?
  approver          User?   @relation("LoanApprover", fields: [approverId], references: [id], onDelete: SetNull)
  allocatedTellerId String?
  allocatedTeller   User?   @relation("LoanAllocatedTeller", fields: [allocatedTellerId], references: [id], onDelete: SetNull)

  employer           String?
  employmentStatus   String?
  grossMonthlyIncome Float?
  netMonthlyIncome   Float?

  repaymentPeriodMonths Int?
  repaymentStartDate    DateTime?
  modeOfRepayment       String?
  collateralOffered     String?

  guarantors Json?

  appraisalScore       Float?
  debtToIncomeRatio    Float?
  recommendedAmount    Float?
  interestRateOverride Float?
  decisionNotes        String?
  disbursementMethod   String?

  approvalDate    DateTime?
  approvedAmount  Float?
  rejectionReason String?

  forwardedAt  DateTime?
  inAnalysisAt DateTime?
  submittedAt  DateTime?
  disbursedAt  DateTime?

  // Deduction Fields
  applyLoanProcessingFee      Boolean? @default(false)
  loanProcessingFeePercentage Float?
  applyLoanInsurance          Boolean? @default(false)
  loanInsurancePercentage     Float?
  applyShareDeduction         Boolean? @default(false)
  shareAmount                 Float?

  // Collateral Fields
  collateralType     String?
  collateralValue    Float?
  forcedSaleValue    Float?
