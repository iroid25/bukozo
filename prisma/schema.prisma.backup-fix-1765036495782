// =====================
// Prisma Schema
// =====================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================
// Enums
// =====================

enum UserRole {
  ADMIN
  BRANCH_MANAGER
  TELLER
  AGENT
  MEMBER
  ACCOUNTANT
  LOAN_OFFICER
  INSTITUTION
  AUDITOR
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  CLOSED
  SUSPENDED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  LOAN_DISBURSEMENT
  LOAN_REPAYMENT
  FLOAT_ALLOCATION
  FLOAT_PURCHASE
  FLOAT_RECONCILIATION
  FEE
  OTHER
}

enum TransactionStatus {
  PENDING
  COMPLETED
  APPROVED
  FAILED
  REVERSED
}

enum LoanStatus {
  PENDING
  APPROVED
  REJECTED
  UNDER_REVIEW
  DISBURSED
  REPAID
  OVERDUE
  WRITTEN_OFF
}

enum NotificationType {
  EMAIL
  SMS
  IN_APP
}

enum LogType {
  SYSTEM
  USER_ACTION
  SECURITY
  ERROR
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  SEPARATED
  OTHER
}

enum OtherSaccosCount {
  NONE
  ONE
  MANY
}

enum FinancialDiscipline {
  EXCELLENT
  NORMAL
  WANTING
}

enum ReconciliationStatus {
  PENDING
  APPROVED
  REJECTED
  UNDER_REVIEW
}

enum ReconciliationType {
  REGULAR
  START_OF_DAY
  END_OF_DAY
}

enum LoanStage {
  DRAFT
  SUBMITTED
  IN_ANALYSIS
  FORWARDED_TO_MANAGER
  APPROVED
  REJECTED
  DISBURSED
  CLOSED
}

enum CategoryKind {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  CASH
  BANK
  MOBILE_MONEY
  OTHER
}

enum RecognitionBasis {
  CASH
  ACCRUAL
  DEDUCTION
}

enum VaultTransactionType {
  INITIAL_DEPOSIT
  FLOAT_ALLOCATION
  FLOAT_RETURN
  BANK_DEPOSIT
  BANK_WITHDRAWAL
  VAULT_TRANSFER
  ADJUSTMENT
  OVERAGE_RECEIVED
  SHORTAGE_WRITTEN_OFF
}

// =====================
// Core Models
// =====================

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id              String    @id @default(cuid())
  name            String
  firstName       String
  lastName        String
  phone           String?   @unique
  email           String    @unique
  dateOfBirth     DateTime?
  address         String?
  nationalId      String?   @unique
  lastLogin       DateTime?
  isActive        Boolean   @default(true)
  emailVerified   DateTime?
  image           String?
  jobTitle        String?
  areaOfOperation String?
  role            UserRole  @default(MEMBER)
  password        String?

  sessions  Session[]
  auditLogs AuditLog[]

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  loanWriteOffsRequested LoanWriteOff[] @relation("WriteOffRequestedBy")
  loanWriteOffsApproved  LoanWriteOff[] @relation("WriteOffApprovedBy")

  notifications           Notification[]
  approvedReconciliations FloatReconciliation[] @relation("ReconciliationApprover")

  userFloat   UserFloat?
  deposits    Deposit[]    @relation("DepositHandler")
  withdrawals Withdrawal[] @relation("WithdrawalHandler")

  loanDisbursements       Loan[]            @relation("LoanDisburser")
  loanApplications        LoanApplication[] @relation("LoanApplicant")
  loanApprovals           LoanApplication[] @relation("LoanApprover")
  allocatedTellerLoans    LoanApplication[] @relation("LoanAllocatedTeller")
  loanOfficerApplications LoanApplication[] @relation("LoanOfficer")
  loanRepayments          LoanRepayment[]   @relation("RepaymentHandler")
  allocatedLoans          Loan[]            @relation("LoanManager")

  loanRepaymentRequests LoanRepaymentRequest[] @relation("RepaymentRequestedBy")

  member                      Member?
  institution                 Institution?
  isVerified                  Boolean                  @default(false)
  token                       String?
  createdAt                   DateTime                 @default(now())
  updatedAt                   DateTime                 @updatedAt
  transactions                Transaction[]
  floatTransactions           FloatTransaction[]       @relation("AgentFloat")
  floatAllocationsAsTeller    FloatAllocation[]        @relation("TellerAgent")
  floatAllocationsAsAllocator FloatAllocation[]        @relation("Allocator")
  floatReconciliation         FloatReconciliation[]
  statements                  Statement[]
  withdrawalVerifications     WithdrawalVerification[] @relation("WithdrawalVerificationHandler")

  expendituresSubmitted ExpenditureRecord[] @relation("ExpSubmittedBy")
  expendituresApproved  ExpenditureRecord[] @relation("ExpApprovedBy")
  incomeRecordsReceived IncomeRecord[]      @relation("IncomeRecordReceivedBy")

  vaultsCustodian              Vault[]               @relation("VaultCustodian")
  vaultTransactionsPerformed   VaultTransaction[]    @relation("VaultTransactionPerformedBy")
  vaultTransactionsRelated     VaultTransaction[]    @relation("VaultTransactionUser")
  vaultReconciliations         VaultReconciliation[] @relation("VaultReconciler")
  vaultReconciliationsApproved VaultReconciliation[] @relation("VaultReconciliationApprover")

  // Suspense Account Relations
  suspenseTransactionsPerformed SuspenseTransaction[] @relation("SuspenseTransactionPerformedBy")
  suspenseTransactionsResolved  SuspenseTransaction[] @relation("SuspenseTransactionResolver")

  // Cash Shortage Relations
  cashShortagesReported CashShortage[] @relation("ShortageReporter")
  cashShortagesOwned    CashShortage[] @relation("ShortageUser")
  cashShortagesResolved CashShortage[] @relation("ShortageResolver")

  // Insurance Relations
  insuranceContributions InsuranceContribution[]
  JournalEntry           JournalEntry[]
  AccountTransaction     AccountTransaction[]

  // Extended Account Relations (Manager Reports)
  savingsTransactions     SavingsTransaction[]  @relation("SavingsTeller")
  shareTransactions       ShareTransaction[]    @relation("ShareTeller")

  // Batch & Session Relations (Manager Reports)
  batchesProcessed        TransactionBatch[]    @relation("BatchProcessor")
  batchesApproved         TransactionBatch[]    @relation("BatchApprover")
  tellerSessions          TransactionSession[]  @relation("SessionTeller")

  // Fixed Asset Relations (Manager Reports)
  assetsResponsible       FixedAsset[]          @relation("AssetResponsible")

  // Standing Order Relations (Manager Reports)
  standingOrdersCreated   StandingOrder[]       @relation("StandingOrderCreator")

  // Customer Feedback Relations (Manager Reports)
  feedbackAssigned        CustomerFeedback[]    @relation("FeedbackAssignee")
  feedbackResolved        CustomerFeedback[]    @relation("FeedbackResolver")
}

// Replace your existing Branch model with this complete version

model Branch {
  id            String   @id @default(cuid())
  name          String   @unique
  location      String
  contactPerson String?
  contactPhone  String?
  email         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users              User[]
  accounts           Account[]
  loans              Loan[]
  floatAllocations   FloatAllocation[]
  incomeRecords      IncomeRecord[]
  expenditureRecords ExpenditureRecord[]
  vaults             Vault[]
  budgets            Budget[]
  suspenseAccounts   SuspenseAccount[]

  // Extended Account Relations (Manager Reports)
  savingsAccounts     SavingsAccount[]
  shareAccounts       ShareAccount[]
  fixedDeposits       FixedDeposit[]

  // Session Relations (Manager Reports)
  tellerSessions      TransactionSession[]

  // Fixed Asset Relations (Manager Reports)
  fixedAssets         FixedAsset[]

  @@index([name])
}

