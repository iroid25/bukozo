  messageId         String?
  cost              Float?
  relatedEntityType String?
  relatedEntityId   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  member            Member?   @relation(fields: [memberId], references: [id])

  @@index([phoneNumber])
  @@index([memberId])
  @@index([smsType])
  @@index([status])
  @@index([sentAt])
}

model CustomerFeedback {
  id              String         @id @default(cuid())
  memberId        String?
  feedbackType    FeedbackType
  subject         String
  description     String
  status          FeedbackStatus @default(PENDING)
  priority        String         @default("MEDIUM")
  submittedDate   DateTime       @default(now())
  assignedToId    String?
  resolvedDate    DateTime?
  resolvedById    String?
  resolution      String?
  resolutionNotes String?
  rating          Int?
  attachments     String[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  assignedTo      User?          @relation("FeedbackAssignee", fields: [assignedToId], references: [id])
  member          Member?        @relation(fields: [memberId], references: [id])
  resolvedBy      User?          @relation("FeedbackResolver", fields: [resolvedById], references: [id])

  @@index([memberId])
  @@index([feedbackType])
  @@index([status])
  @@index([submittedDate])
  @@index([assignedToId])
}

model BranchReserveAllocation {
  id                   String            @id @default(cuid())
  amount               Float
  floatAmount          Float             @default(0)
  sourceVaultId        String
  targetVaultId        String
  status               TransactionStatus @default(PENDING)
  type                 AllocationType    @default(ALLOCATION)
  allocatedByUserId    String
  confirmedByUserId    String?
  createdAt            DateTime          @default(now())
  confirmationDate     DateTime?
  notes                String?
  physicalCashEntered  Float?
  physicalFloatEntered Float?
  allocatedByUser      User              @relation("AllocatedBy", fields: [allocatedByUserId], references: [id])
  confirmedByUser      User?             @relation("ConfirmedBy", fields: [confirmedByUserId], references: [id])
  sourceVault          Vault             @relation("SourceVault", fields: [sourceVaultId], references: [id])
  targetVault          Vault             @relation("TargetVault", fields: [targetVaultId], references: [id])

  @@index([sourceVaultId])
  @@index([targetVaultId])
  @@index([status])
}

model LoanReschedule {
  id                    String           @id @default(cuid())
  loanId                String
  oldDueDate            DateTime
  newDueDate            DateTime
  reason                String
  status                RescheduleStatus @default(PENDING)
  requestedById         String
  approvedById          String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  village               String?
  parish                String?
  county                String?
  spouseName            String?
  spouseContact         String?
  spouseNIN             String?
  rescheduleAmount      Float?
  reschedulePeriod      String?
  securityType          String?
  securityDescription   String?
  securityPurchasePrice Float?
  securityCurrentPrice  Float?
  securityValuation     Float?
  forcedSaleValue       Float?
  guarantors            Json?
  officerComment        String?
  managerComment        String?
  committeeComment      String?
  minuteNumber          String?
  loanOfficerId         String?
  approvedBy            User?            @relation("RescheduleApprover", fields: [approvedById], references: [id])
  loan                  Loan             @relation(fields: [loanId], references: [id], onDelete: Cascade)
  loanOfficer           User?            @relation("RescheduleOfficer", fields: [loanOfficerId], references: [id])
  requestedBy           User             @relation("RescheduleRequester", fields: [requestedById], references: [id])

  @@index([loanId])
  @@index([status])
}

model InstitutionWithdrawal {
  id                 String      @id @default(cuid())
  withdrawalId       String      @unique
  institutionId      String
  recipientName      String
  recipientIdNumber  String?
  recipientPhone     String?
  recipientRelation  String?
  tellerVerified     Boolean     @default(false)
  verifiedAt         DateTime?
  verifiedByUserId   String?
  signatoryApprovals Json
  mandateMet         Boolean     @default(false)
  notes              String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  institution        Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  verifiedBy         User?       @relation("InstitutionWithdrawalVerifier", fields: [verifiedByUserId], references: [id])
  withdrawal         Withdrawal  @relation(fields: [withdrawalId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@index([withdrawalId])
  @@index([tellerVerified])
}

model AccountHold {
  id             String       @id @default(cuid())
  accountId      String
  memberId       String
  institutionId  String?
  reason         HoldReason   @default(MANUAL_HOLD)
  reasonText     String?
  loanId         String?
  placedByUserId String
  liftedByUserId String?
  placedAt       DateTime     @default(now())
  liftedAt       DateTime?
  isActive       Boolean      @default(true)
  notes          String?
  liftNotes      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  account        Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  institution    Institution? @relation(fields: [institutionId], references: [id])
  liftedBy       User?        @relation("HoldLifter", fields: [liftedByUserId], references: [id])
  loan           Loan?        @relation(fields: [loanId], references: [id])
  member         Member       @relation(fields: [memberId], references: [id])
  placedBy       User         @relation("HoldPlacer", fields: [placedByUserId], references: [id])

  @@index([accountId, isActive])
  @@index([memberId])
  @@index([institutionId])
  @@index([loanId])
  @@index([placedByUserId])
}

model AccountNumberSequence {
  id         String   @id @default(cuid())
  year       Int      @unique
  lastNumber Int      @default(0)
  prefix     String?
  format     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model GlobalFeeConfiguration {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedBy String?
  updatedAt DateTime @updatedAt
}

model StaffLimit {
  id                  String   @id @default(cuid())
  role                UserRole @unique
  perTransactionLimit Float    @default(0)
  dailyLimit          Float    @default(0)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model SystemConfiguration {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  dataType    String   @default("STRING")
  isActive    Boolean  @default(true)
  category    String   @default("GENERAL")
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([key])
}

model LoanRepaymentSchedule {
  id               String   @id @default(cuid())
  loanId           String
  period           Int
  dueDate          DateTime
  principalPayment Float
  interestPayment  Float
  totalPayment     Float
  remainingBalance Float
  paidAmount       Float    @default(0)
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  loan             Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([status])
  @@index([dueDate])
}

model InstitutionLoanRepaymentSchedule {
  id               String          @id @default(cuid())
  loanId           String
  period           Int
  dueDate          DateTime
  principalPayment Float
  interestPayment  Float
  totalPayment     Float
  remainingBalance Float
  paidAmount       Float           @default(0)
  status           String          @default("PENDING")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  loan             InstitutionLoan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([status])
  @@index([dueDate])
}

model LoanLedgerTransaction {
  id               String   @id @default(cuid())
  loanId           String
  transactionDate  DateTime @default(now())
  transactionType  String
  voucherNo        String?
  debitPrincipal   Float    @default(0)
  debitInterest    Float    @default(0)
  creditPrincipal  Float    @default(0)
  creditInterest   Float    @default(0)
  balancePrincipal Float
  balanceInterest  Float
  balanceTotal     Float
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  loan             Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([transactionDate])
  @@index([transactionType])
}

model InstitutionLoanLedgerTransaction {
  id               String          @id @default(cuid())
  loanId           String
  transactionDate  DateTime        @default(now())
  transactionType  String
  voucherNo        String?
  debitPrincipal   Float           @default(0)
  debitInterest    Float           @default(0)
  creditPrincipal  Float           @default(0)
  creditInterest   Float           @default(0)
  balancePrincipal Float
  balanceInterest  Float
  balanceTotal     Float
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  loan             InstitutionLoan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([transactionDate])
  @@index([transactionType])
}

