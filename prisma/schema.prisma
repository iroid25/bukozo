model ChartOfAccount {
  id                        String               @id @default(cuid())
  accountCode               String               @unique
  accountName               String
  fullCode                  String               @unique
  parentId                  String?
  level                     Int
  category                  String?
  product                   String?
  currency                  String               @default("UGX")
  debitCredit               String?
  description               String?
  notes                     String?
  isActive                  Boolean              @default(true)
  isSystem                  Boolean              @default(false)
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  balance                   Float                @default(0)
  debitBalance              Float                @default(0)
  creditBalance             Float                @default(0)
  ledgerType                AccountLedgerType
  creditTransactions        AccountTransaction[] @relation("CreditAccount")
  debitTransactions         AccountTransaction[] @relation("DebitAccount")
  accountTypes              AccountType[]
  parent                    ChartOfAccount?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  children                  ChartOfAccount[]     @relation("AccountHierarchy")
  assetAccounts             FixedAsset[]         @relation("AssetAccount")
  assetAccumulatedDeps      FixedAsset[]         @relation("AssetAccumulatedDepreciation")
  assetDepreciationExpenses FixedAsset[]         @relation("AssetDepreciationExpense")
  journalEntries            JournalEntry[]
  productFees               LoanProduct[]        @relation("ProductFee")
  productInterests          LoanProduct[]        @relation("ProductInterest")
  productLedgers            LoanProduct[]        @relation("ProductLedger")
  productPenalties          LoanProduct[]        @relation("ProductPenalty")
  transactionCredits        Transaction[]        @relation("TransactionCredit")
  transactionDebits         Transaction[]        @relation("TransactionDebit")

  @@index([accountCode])
  @@index([ledgerType])
  @@index([parentId])
  @@index([isActive])
}

model JournalEntry {
