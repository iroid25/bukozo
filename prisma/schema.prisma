generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                                   String                       @id @default(cuid())
  name                                 String
  firstName                            String
  lastName                             String
  phone                                String?                      @unique
  email                                String?                      @unique
  dateOfBirth                          DateTime?
  address                              String?
  nationalId                           String?                      @unique
  lastLogin                            DateTime?
  isActive                             Boolean                      @default(true)
  emailVerified                        DateTime?
  image                                String?
  jobTitle                             String?
  areaOfOperation                      String?
  role                                 UserRole                     @default(MEMBER)
  password                             String?
  branchId                             String?
  isVerified                           Boolean                      @default(false)
  token                                String?
  createdAt                            DateTime                     @default(now())
  updatedAt                            DateTime                     @updatedAt
  passwordExpiryDays                   Int?                         @default(90)
  passwordLastChanged                  DateTime?                    @default(now())
  requiresPasswordChange               Boolean                      @default(true)
  passwordResetExpires                 DateTime?
  passwordResetToken                   String?                      @unique
  accountHoldsLifted                   AccountHold[]                @relation("HoldLifter")
  accountHoldsPlaced                   AccountHold[]                @relation("HoldPlacer")
  AccountTransaction                   AccountTransaction[]
  accountingAttachments                AccountingAttachment[]       @relation("AccountingAttachmentUploadedBy")
  auditLogs                            AuditLog[]
  bankStatementImports                 BankStatementImport[]        @relation("BankStatementImportImportedBy")
  branchAccountant                     Branch[]                     @relation("BranchAccountant")
  branchManager                        Branch[]                     @relation("BranchManager")
  reserveAllocationsPerformed          BranchReserveAllocation[]    @relation("AllocatedBy")
  reserveAllocationsConfirmed          BranchReserveAllocation[]    @relation("ConfirmedBy")
  cashShortagesReported                CashShortage[]               @relation("ShortageReporter")
  cashShortagesResolved                CashShortage[]               @relation("ShortageResolver")
  cashShortagesOwned                   CashShortage[]               @relation("ShortageUser")
  feedbackAssigned                     CustomerFeedback[]           @relation("FeedbackAssignee")
  feedbackResolved                     CustomerFeedback[]           @relation("FeedbackResolver")
  deposits                             Deposit[]                    @relation("DepositHandler")
  expendituresApproved                 ExpenditureRecord[]          @relation("ExpApprovedBy")
  expendituresSubmitted                ExpenditureRecord[]          @relation("ExpSubmittedBy")
  assetsResponsible                    FixedAsset[]                 @relation("AssetResponsible")
  floatAllocationsAsAllocator          FloatAllocation[]            @relation("Allocator")
  floatAllocationsAsTeller             FloatAllocation[]            @relation("TellerAgent")
  approvedReconciliations              FloatReconciliation[]        @relation("ReconciliationApprover")
  floatReconciliation                  FloatReconciliation[]
  floatTransactions                    FloatTransaction[]           @relation("AgentFloat")
  incomeRecordsReceived                IncomeRecord[]               @relation("IncomeRecordReceivedBy")
  institution                          Institution?
  institutionLoansAllocated            InstitutionLoan[]            @relation("InstitutionLoanManager")
  institutionLoanApplicationsAllocated InstitutionLoanApplication[] @relation("InstitutionLoanAllocatedTeller")
  institutionLoanApplicantApplications InstitutionLoanApplication[] @relation("InstitutionLoanApplicant")
  institutionLoanOfficerApplications   InstitutionLoanApplication[] @relation("InstitutionLoanOfficer")
  institutionWithdrawalVerifications   InstitutionWithdrawal[]      @relation("InstitutionWithdrawalVerifier")
  insuranceContributions               InsuranceContribution[]
  JournalEntry                         JournalEntry[]
  allocatedLoans                       Loan[]                       @relation("LoanManager")
  loanDisbursements                    Loan[]                       @relation("LoanDisburser")
  allocatedTellerLoans                 LoanApplication[]            @relation("LoanAllocatedTeller")
  loanApplications                     LoanApplication[]            @relation("LoanApplicant")
  loanApprovals                        LoanApplication[]            @relation("LoanApprover")
  loanOfficerApplications              LoanApplication[]            @relation("LoanOfficer")
  loanRepayments                       LoanRepayment[]              @relation("RepaymentHandler")
  loanRepaymentRequests                LoanRepaymentRequest[]       @relation("RepaymentRequestedBy")
  rescheduleApprovals                  LoanReschedule[]             @relation("RescheduleApprover")
  rescheduleOfficer                    LoanReschedule[]             @relation("RescheduleOfficer")
  rescheduleRequests                   LoanReschedule[]             @relation("RescheduleRequester")
  loanWriteOffsApproved                LoanWriteOff[]               @relation("WriteOffApprovedBy")
  loanWriteOffsRequested               LoanWriteOff[]               @relation("WriteOffRequestedBy")
  membersApproved                      Member[]                     @relation("MemberApprover")
  member                               Member?
  notifications                        Notification[]
  savingsTransactions                  SavingsTransaction[]         @relation("SavingsTeller")
  sessions                             Session[]
  shareTransactions                    ShareTransaction[]           @relation("ShareTeller")
  standingOrdersCreated                StandingOrder[]              @relation("StandingOrderCreator")
  statements                           Statement[]
  suspenseTransactionsPerformed        SuspenseTransaction[]        @relation("SuspenseTransactionPerformedBy")
  suspenseTransactionsResolved         SuspenseTransaction[]        @relation("SuspenseTransactionResolver")
  transactions                         Transaction[]
  batchesApproved                      TransactionBatch[]           @relation("BatchApprover")
  batchesProcessed                     TransactionBatch[]           @relation("BatchProcessor")
  tellerSessions                       TransactionSession[]         @relation("SessionTeller")
  branch                               Branch?                      @relation(fields: [branchId], references: [id])
  userFloat                            UserFloat?
  vaultsCustodian                      Vault[]                      @relation("VaultCustodian")
  vaultReconciliationsApproved         VaultReconciliation[]        @relation("VaultReconciliationApprover")
  vaultReconciliations                 VaultReconciliation[]        @relation("VaultReconciler")
  vaultTransactionsPerformed           VaultTransaction[]           @relation("VaultTransactionPerformedBy")
  vaultTransactionsRelated             VaultTransaction[]           @relation("VaultTransactionUser")
  withdrawals                          Withdrawal[]                 @relation("WithdrawalHandler")
  withdrawalVerifications              WithdrawalVerification[]     @relation("WithdrawalVerificationHandler")
}

model Branch {
  id                 String               @id @default(cuid())
  name               String               @unique
  location           String
  contactPerson      String?
  contactPhone       String?
  email              String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  accountantId       String?
  managerId          String?
  accounts           Account[]
  accountant         User?                @relation("BranchAccountant", fields: [accountantId], references: [id])
  manager            User?                @relation("BranchManager", fields: [managerId], references: [id])
  budgets            Budget[]
  expenditureRecords ExpenditureRecord[]
  fixedAssets        FixedAsset[]
  fixedDeposits      FixedDeposit[]
  floatAllocations   FloatAllocation[]
  incomeRecords      IncomeRecord[]
  loans              Loan[]
  savingsAccounts    SavingsAccount[]
  shareAccounts      ShareAccount[]
  suspenseAccounts   SuspenseAccount[]
  tellerSessions     TransactionSession[]
  users              User[]
  vaults             Vault[]

  @@index([name])
}

model Vault {
  id                             String                    @id @default(cuid())
  name                           String                    @unique
  branchId                       String?
  balance                        Float                     @default(0)
  physicalCash                   Float                     @default(0)
  lastVerified                   DateTime?
  isActive                       Boolean                   @default(true)
  location                       String?
  custodianUserId                String?
  createdAt                      DateTime                  @default(now())
  updatedAt                      DateTime                  @updatedAt
  branchReserveAllocationsSource BranchReserveAllocation[] @relation("SourceVault")
  branchReserveAllocationsTarget BranchReserveAllocation[] @relation("TargetVault")
  branch                         Branch?                   @relation(fields: [branchId], references: [id])
  custodian                      User?                     @relation("VaultCustodian", fields: [custodianUserId], references: [id])
  vaultReconciliations           VaultReconciliation[]
  vaultTransactions              VaultTransaction[]

  @@index([branchId])
  @@index([isActive])
}

model VaultTransaction {
  id                           String               @id @default(cuid())
  vaultId                      String
  type                         VaultTransactionType
  amount                       Float
  balanceBefore                Float
  balanceAfter                 Float
  transactionDate              DateTime             @default(now())
  description                  String?
  relatedFloatAllocationId     String?
  relatedFloatReconciliationId String?
  relatedUserId                String?
  performedByUserId            String
  createdAt                    DateTime             @default(now())
  performedBy                  User                 @relation("VaultTransactionPerformedBy", fields: [performedByUserId], references: [id], onDelete: Cascade)
  relatedUser                  User?                @relation("VaultTransactionUser", fields: [relatedUserId], references: [id])
  vault                        Vault                @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  @@index([vaultId])
  @@index([type])
  @@index([transactionDate])
}

model VaultReconciliation {
  id                 String               @id @default(cuid())
  vaultId            String
  reconciliationDate DateTime             @default(now())
  systemBalance      Float
  physicalCash       Float
  difference         Float
  isBalanced         Boolean
  reconciledByUserId String
  status             ReconciliationStatus @default(PENDING)
  approvedByUserId   String?
  approvalDate       DateTime?
  notes              String?
  approvedBy         User?                @relation("VaultReconciliationApprover", fields: [approvedByUserId], references: [id])
  reconciledBy       User                 @relation("VaultReconciler", fields: [reconciledByUserId], references: [id], onDelete: Cascade)
  vault              Vault                @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  @@index([vaultId])
  @@index([reconciliationDate])
  @@index([status])
}

model SubCounty {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  parishes  Parish[]

  @@index([name])
}

model Parish {
  id          String    @id @default(cuid())
  name        String
  subCountyId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  subCounty   SubCounty @relation(fields: [subCountyId], references: [id], onDelete: Cascade)

  @@unique([subCountyId, name])
  @@index([name])
  @@index([subCountyId])
}

model Notification {
  id            String           @id @default(cuid())
  userId        String?
  type          NotificationType
  subject       String?
  message       String
  sentAt        DateTime         @default(now())
  isRead        Boolean          @default(false)
  targetAddress String?
  status        String?
  user          User?            @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([sentAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  oldValue   Json?
  newValue   Json?
  timestamp  DateTime @default(now())
  ipAddress  String?
  browser    String?
  os         String?
  userAgent  String?
  details    Json?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityType])
  @@index([timestamp])
}

model CustomerAuditTrail {
  id               String                    @id @default(cuid())
  auditEventId     String
  actionType       String
  snapshotType     CustomerAuditSnapshotType
  branchId         String?
  branchCode       String?
  branchName       String?
  changedBy        String?
  changedByUserId  String?
  changedAt        DateTime                  @default(now())
  customerId       String
  fullName         String?
  dateOfBirth      DateTime?
  sex              String?
  address          String?
  phone            String?
  mobile           String?
  idCardNumber     String?
  refNumber        String?
  registrationDate DateTime?
  groupCode        String?
  groupName        String?
  previousRowId    String?
  nextRowId        String?

  @@index([auditEventId])
  @@index([customerId])
  @@index([branchId])
  @@index([actionType])
  @@index([changedAt])
}

model ApiKey {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  createdAt DateTime @default(now())
}

model Member {
  id                         String                   @id @default(cuid())
  userId                     String                   @unique
  memberNumber               String                   @unique
  registrationDate           DateTime                 @default(now())
  isApproved                 Boolean                  @default(false)
  surname                    String?
  otherNames                 String?
  age                        Int?
  gender                     Gender?
  maritalStatus              MaritalStatus?
  maritalOther               String?
  nokName                    String?
  nokRelationship            String?
  nokPhone                   String?
  numberOfChildren           Int?
  numberOfDependants         Int?
  levelOfEducation           String?
  citizenship                String?
  occupation                 String?
  otherFinancialInstitutions String?
  fatherName                 String?
  motherName                 String?
  village                    String?
  parish                     String?
  subCounty                  String?
  constituency               String?
  town                       String?
  district                   String?
  postalAddress              String?
  nin                        String?
  typeOfId                   String?
  certifiedBy                String?
  certifierAccountNo         String?
  certifierPhone             String?
  certifierSignature         String?
  certificationDate          DateTime?
  withdrawalInstructions     String?
  applicantOccupationLC      String?
  designationLC              String?
  locationLC                 String?
  otherSaccosCount           OtherSaccosCount?
  financialDiscipline        FinancialDiscipline?
  recommenderName            String?
  recommenderTitle           String?
  recommenderPhone           String?
  recommenderSignature       String?
  recommendationDate         DateTime?
  entryFee                   Float?
  initialSavings             Float?
  nominee                    String?
  applicantSignature         String?
  approvalDate               DateTime?
  rejectionReason            String?
  savingsAccountNumber       String?
  managerSignature           String?
  cashierSignature           String?
  officialStamp              String?
  passportPhoto              String?
  idCopyPath                 String?
  additionalDocs             String[]
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  fingerprintTemplate        String?
  status                     MemberStatus             @default(PENDING_APPROVAL)
  approvalStatus             MemberApprovalStatus     @default(PENDING)
  approvedAt                 DateTime?
  approvedByUserId           String?
  fingerprintQuality         Int?
  fingerprintEnrolledAt      DateTime?
  fingerprintUpdatedAt       DateTime?
  guardianAccounts           Account[]                @relation("AccountGuardian")
  accounts                   Account[]
  accountHolds               AccountHold[]
  customerFeedback           CustomerFeedback[]
  deposits                   Deposit[]                @relation("MemberDeposits")
  fingerprintLogs            FingerprintLog[]
  fixedDeposits              FixedDeposit[]
  incomeRecords              IncomeRecord[]           @relation("MemberIncomeRecords")
  insuranceContributions     InsuranceContribution[]
  loans                      Loan[]
  loanAppeals                LoanAppeal[]             @relation("MemberLoanAppeals")
  loanApplications           LoanApplication[]        @relation("MemberLoanApplications")
  loanRepayments             LoanRepayment[]          @relation("MemberLoanRepayments")
  loanRepaymentRequests      LoanRepaymentRequest[]
  approvedBy                 User?                    @relation("MemberApprover", fields: [approvedByUserId], references: [id])
  user                       User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  savingsAccounts            SavingsAccount[]
  shareAccounts              ShareAccount[]
  smsLogs                    SmsLog[]
  statements                 Statement[]
  transactions               Transaction[]            @relation("MemberTransactions")
  withdrawals                Withdrawal[]             @relation("MemberWithdrawals")
  withdrawalVerifications    WithdrawalVerification[]

  @@index([memberNumber])
  @@index([registrationDate])
  @@index([userId])
  @@index([approvalStatus])
}

model AccountType {
  id                          String           @id @default(cuid())
  name                        String           @unique
  interestRate                Float            @default(0)
  interestPeriod              String           @default("MONTHLY")
  minBalance                  Float            @default(0)
  isDefault                   Boolean          @default(false)
  maxWithdrawal               Float?
  isLoanEligible              Boolean          @default(true)
  monthlyCharge               Float?
  withdrawalFeeTiers          String?
  flatWithdrawalFee           Float?
  withdrawalFrequencyDays     Int?
  maxWithdrawalsPerDay        Int?
  hasFixedPeriod              Boolean          @default(false)
  fixedPeriodMonths           Int?
  maturityTransferAccountType String?
  isShareAccount              Boolean          @default(false)
  canWithdraw                 Boolean          @default(true)
  earnsDividends              Boolean          @default(false)
  createdAt                   DateTime         @default(now())
  updatedAt                   DateTime         @updatedAt
  withdrawalFeePercentage     Float?
  sharePrice                  Float?           @default(10000)
  ledgerAccountId             String?
  accounts                    Account[]
  ledgerAccount               ChartOfAccount?  @relation(fields: [ledgerAccountId], references: [id])
  savingsAccounts             SavingsAccount[]
  shareAccounts               ShareAccount[]

  @@index([name])
  @@index([ledgerAccountId])
}

model Account {
  id                            String                   @id @default(cuid())
  accountNumber                 String                   @unique
  memberId                      String?
  institutionId                 String?
  accountTypeId                 String
  balance                       Float                    @default(0)
  status                        AccountStatus            @default(ACTIVE)
  openedAt                      DateTime                 @default(now())
  closedAt                      DateTime?
  branchId                      String
  customFlatWithdrawalFee       Float?
  customWithdrawalFeePercentage Float?
  customWithdrawalFeeTiers      String?
  isAutoGenerated               Boolean                  @default(true)
  customNumberApprovedBy        String?
  customNumberApprovedAt        DateTime?
  expectedInterest              Float?
  fixingEndDate                 DateTime?
  fixingStartDate               DateTime?
  fundingSourceAccountId        String?
  initialDepositReceiptNo       String?
  sharesCount                   Int?
  guardianMemberId              String?
  accountType                   AccountType              @relation(fields: [accountTypeId], references: [id], onDelete: Cascade)
  branch                        Branch                   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  guardian                      Member?                  @relation("AccountGuardian", fields: [guardianMemberId], references: [id])
  institution                   Institution?             @relation(fields: [institutionId], references: [id])
  member                        Member?                  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  accountHolds                  AccountHold[]
  deposits                      Deposit[]
  incomeRecords                 IncomeRecord[]           @relation("AccountIncomeRecords")
  insuranceContributions        InsuranceContribution[]
  loanRepaymentRequests         LoanRepaymentRequest[]
  transactions                  Transaction[]
  withdrawals                   Withdrawal[]
  withdrawalVerifications       WithdrawalVerification[]

  @@index([accountNumber])
  @@index([memberId])
  @@index([institutionId])
  @@index([accountTypeId])
  @@index([branchId])
  @@index([guardianMemberId])
}

model Transaction {
  id                   String                 @id @default(cuid())
  transactionRef       String                 @unique
  memberId             String?                @map("sourceMemberId")
  accountId            String                 @map("targetAccountId")
  type                 TransactionType
  amount               Float                  @default(0)
  currency             String                 @default("UGX")
  exchangeRate         Float                  @default(1.0)
  status               TransactionStatus      @default(PENDING)
  description          String?
  transactionDate      DateTime               @default(now())
  valueDate            DateTime?
  processedByUserId    String?
  branchId             String?
  customerId           String?
  loanId               String?
  scheduleId           String?
  paymentMethod        String?
  paymentReference     String?
  notes                String?
  relatedTransactionId String?
  externalReference    String?
  channel              String?
  institutionId        String?
  creditAccountId      String?
  debitAccountId       String?
  fee                  Float                  @default(0)
  accountTransactions  AccountTransaction[]
  attachments          AccountingAttachment[] @relation("AccountingAttachmentTransaction")
  matchedBankLines     BankStatementLine?     @relation("BankStatementLineMatchedTransaction")
  deposit              Deposit?
  journalEntries       JournalEntry[]         @relation("TransactionJournalEntries")
  creditAccount        ChartOfAccount?        @relation("TransactionCredit", fields: [creditAccountId], references: [id])
  debitAccount         ChartOfAccount?        @relation("TransactionDebit", fields: [debitAccountId], references: [id])
  institution          Institution?           @relation("InstitutionTransactions", fields: [institutionId], references: [id])
  processedByUser      User?                  @relation(fields: [processedByUserId], references: [id])
  member               Member?                @relation("MemberTransactions", fields: [memberId], references: [id], onDelete: Cascade)
  account              Account                @relation(fields: [accountId], references: [id], onDelete: Cascade)
  withdrawal           Withdrawal?

  @@index([memberId])
  @@index([accountId])
  @@index([type])
  @@index([transactionDate])
  @@index([status])
  @@index([institutionId])
}

model Deposit {
  id              String       @id @default(cuid())
  transactionId   String       @unique
  memberId        String?
  accountId       String
  amount          Float
  depositDate     DateTime     @default(now())
  handlerUserId   String
  channel         String
  mobileMoneyRef  String?
  depositorName   String?
  institutionId   String?
  depositType     DepositType  @default(DIRECT)
  feeType         String?
  studentClass    String?
  studentName     String?
  studentYear     String?
  institutionName String?
  account         Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  handler         User         @relation("DepositHandler", fields: [handlerUserId], references: [id], onDelete: Cascade)
  institution     Institution? @relation("InstitutionDeposits", fields: [institutionId], references: [id], onDelete: Cascade)
  member          Member?      @relation("MemberDeposits", fields: [memberId], references: [id], onDelete: Cascade)
  transaction     Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([handlerUserId])
  @@index([depositType])
}

model Withdrawal {
  id                    String                 @id @default(cuid())
  transactionId         String                 @unique
  memberId              String?
  accountId             String
  amount                Float
  withdrawalDate        DateTime               @default(now())
  handlerUserId         String
  channel               String
  mobileMoneyRef        String?
  institutionId         String?
  fee                   Float                  @default(0)
  institutionWithdrawal InstitutionWithdrawal?
  account               Account                @relation(fields: [accountId], references: [id], onDelete: Cascade)
  handler               User                   @relation("WithdrawalHandler", fields: [handlerUserId], references: [id], onDelete: Cascade)
  institution           Institution?           @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  member                Member?                @relation("MemberWithdrawals", fields: [memberId], references: [id], onDelete: Cascade)
  transaction           Transaction            @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([institutionId])
  @@index([handlerUserId])
}

model WithdrawalVerification {
  id               String                @id @default(cuid())
  memberId         String?
  accountId        String
  amount           Float
  channel          String
  mobileMoneyRef   String?
  description      String?
  verificationCode String
  handlerUserId    String
  expiresAt        DateTime
  emailSent        Boolean               @default(false)
  smsSent          Boolean               @default(false)
  isUsed           Boolean               @default(false)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  institutionId    String?
  signatoryId      String?
  metadata         Json?
  account          Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  handler          User                  @relation("WithdrawalVerificationHandler", fields: [handlerUserId], references: [id], onDelete: Cascade)
  institution      Institution?          @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  member           Member?               @relation(fields: [memberId], references: [id], onDelete: Cascade)
  signatory        InstitutionSignatory? @relation(fields: [signatoryId], references: [id])

  @@index([memberId])
  @@index([institutionId])
  @@index([accountId])
  @@index([handlerUserId])
  @@index([verificationCode])
  @@index([expiresAt])
  @@index([isUsed])
}

model FingerprintLog {
  id                      Int                       @id @default(autoincrement())
  memberId                String?
  institutionSignatoryId  String?
  action                  String
  quality                 Int?
  score                   Int?
  ipAddress               String?
  createdAt               DateTime                  @default(now())
  member                  Member?                   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  institutionSignatory    InstitutionSignatory?     @relation(fields: [institutionSignatoryId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([institutionSignatoryId])
  @@index([action])
  @@index([createdAt])
}

model LoanProduct {
  id                          String                       @id @default(cuid())
  name                        String                       @unique
  minAmount                   Float
  maxAmount                   Float
  interestRate                Float
  repaymentPeriodDays         Int
  description                 String?
  isActive                    Boolean                      @default(true)
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  interestType                InterestType                 @default(FLAT_RATE)
  interestPeriod              InterestPeriod               @default(MONTHLY)
  feeAccountId                String?
  interestAccountId           String?
  ledgerAccountId             String?
  penaltyAccountId            String?
  institutionLoanApplications InstitutionLoanApplication[]
  loanApplications            LoanApplication[]
  feeAccount                  ChartOfAccount?              @relation("ProductFee", fields: [feeAccountId], references: [id])
  interestAccount             ChartOfAccount?              @relation("ProductInterest", fields: [interestAccountId], references: [id])
  ledgerAccount               ChartOfAccount?              @relation("ProductLedger", fields: [ledgerAccountId], references: [id])
  penaltyAccount              ChartOfAccount?              @relation("ProductPenalty", fields: [penaltyAccountId], references: [id])

  @@index([name])
}

model LoanApplication {
  id                            String                  @id @default(cuid())
  loanProductId                 String
  memberId                      String
  loanOfficerId                 String?
  amountApplied                 Float
  applicationDate               DateTime                @default(now())
  status                        LoanStatus              @default(PENDING)
  stage                         LoanStage               @default(DRAFT)
  purpose                       String?
  applicantId                   String?
  approverId                    String?
  allocatedTellerId             String?
  employer                      String?
  employmentStatus              String?
  grossMonthlyIncome            Float?
  netMonthlyIncome              Float?
