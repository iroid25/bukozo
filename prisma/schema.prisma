  transaction     Transaction?           @relation("TransactionJournalEntries", fields: [transactionId], references: [id])

  @@index([accountId])
  @@index([entryNumber])
  @@index([entryDate])
  @@index([transactionId])
  @@index([branchId])
}

model AccountTransaction {
