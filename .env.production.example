# ──────────────────────────────────────────────────────────────────────────
# Production environment for the Docker deployment.
#
# Copy this file to `.env.production` and fill in real values:
#   cp .env.production.example .env.production
#
# `.env.production` is used TWICE by docker-compose:
#   1. As the source for ${VAR} substitution in docker-compose.yml's build
#      "args:" (the NEXT_PUBLIC_* values, which get inlined into the client
#      bundle at build time).
#   2. As the runtime "env_file:" injected into the running container.
#
# Because of (1), always run compose commands with --env-file, e.g.:
#   docker compose --env-file .env.production build --no-cache
#   docker compose --env-file .env.production up -d
# (the provided Makefile does this for you)
#
# Never commit .env.production — it is already covered by .gitignore's
# `.env*` rules. Do not put real secrets in this .example file.
# ──────────────────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────
# DOCKER IMAGE (optional)
# ──────────────────────────────────────────────
# Leave unset for local builds (docker-compose.yml defaults to
# bukonze-nextjs:latest, built from the local Dockerfile). Only set this on
# the VPS if you're using the GHCR-based CI/CD flow in
# .github/workflows/deploy.yml, so `docker compose pull` fetches the image
# GitHub Actions just pushed instead of trying to build locally:
# IMAGE_NAME="ghcr.io/your-github-owner/your-repo-name:latest"

# ──────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ──────────────────────────────────────────────
# AUTHENTICATION (NextAuth)
# ──────────────────────────────────────────────
NEXTAUTH_SECRET="generate-a-strong-random-secret"
# Must be the public URL the app is served at (behind Nginx/SSL in production)
NEXTAUTH_URL="https://your-domain.com"

# ──────────────────────────────────────────────
# APP (public – inlined into the browser bundle at BUILD time)
# ──────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL="https://your-domain.com"
NEXT_PUBLIC_BASE_URL="https://your-domain.com"
NEXT_PUBLIC_APP_URL="https://your-domain.com"
NEXT_PUBLIC_APP_NAME="Bukonz SACCO"
NEXT_PUBLIC_CURRENCY="UGX"
NEXT_PUBLIC_COUNTRY_CODE="256"

# ──────────────────────────────────────────────
# EMAIL (Resend)
# ──────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="Bukonz SACCO <noreply@your-domain.com>"

# ──────────────────────────────────────────────
# FILE UPLOADS (UploadThing)
# ──────────────────────────────────────────────
UPLOADTHING_TOKEN="eyJ..."

# ──────────────────────────────────────────────
# SMS – Africa's Talking
# ──────────────────────────────────────────────
AFRICASTALKING_API_KEY="your-api-key"
AFRICASTALKING_USERNAME="your-username"
AFRICASTALKING_SENDER_ID=""

# ──────────────────────────────────────────────
# PAYMENT – MTN Mobile Money (Relworx)
# ──────────────────────────────────────────────
RELWORX_API_KEY=""
RELWORX_ACCOUNT_NO=""
RELWORX_BASE_URL="https://payments.relworx.com/api"
RELWORX_WEBHOOK_KEY=""
# Must match EXACTLY what is registered in the Relworx dashboard
RELWORX_WEBHOOK_URL="https://your-domain.com/api/webhooks/relworx"
RELWORX_STATUS_POLL_AFTER_MS="180000"

# Cron endpoint auth (used by /api/cron/* routes — see vercel.json for the
# schedules to replicate with a VPS cron job / systemd timer hitting curl)
CRON_SECRET=""

# ──────────────────────────────────────────────
# PAYMENT – MTN MoMo (direct API)
# ──────────────────────────────────────────────
MOMO_TARGET_ENV="production"
MOMO_TYPE="production"
MOMO_CURRENCY="UGX"
MOMO_COLLECTIONS_SUB_KEY=""
MOMO_DISBURSEMENTS_SUB_KEY=""

# ──────────────────────────────────────────────
# PAYMENT – Pesapal
# ──────────────────────────────────────────────
PESAPAL_CONSUMER_KEY=""
PESAPAL_CONSUMER_SECRET=""
PESAPAL_ENVIRONMENT="production"
PESAPAL_IPM_ID=""
